{
  "appId": "com.launchpad.app",
  "appName": "LaunchPad",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "launchpad"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f0f1a",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    }
  }
}
